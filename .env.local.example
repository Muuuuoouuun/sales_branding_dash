# Google Sheets Configuration
# 1. Create a Google Service Account in Google Cloud Console
# 2. Download the JSON key file
# 3. Share your Google Sheet with the Service Account email (e.g. your-sa@project.iam.gserviceaccount.com)

# Spreadsheet ID from the URL: https://docs.google.com/spreadsheets/d/[SPREADSHEET_ID]/edit
GOOGLE_SHEET_ID=your_spreadsheet_id_here

# Service Account Credentials (either provide the path to the JSON file or the values below)
# Option A: Path to the JSON file (place it in the root directory)
# GOOGLE_APPLICATION_CREDENTIALS=service-account.json

# Option B: Direct Environment Variables (Recommended for Vercel/Deployment)
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
